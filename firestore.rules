rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- SHARED HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATIONS ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 2000 &&
             data.createdAt == request.time;
    }

    // --- RULES ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Users shouldn't be listable normally
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio']) &&
                      (incoming().displayName is string && incoming().displayName.size() <= 100);
    }

    // 2. Circles Collection
    match /circles/{circleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false; // Managed by admin or seed data for now
    }

    // 3. Messages in Circles
    match /circles/{circleId}/messages/{messageId} {
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming());
    }
  }
}
